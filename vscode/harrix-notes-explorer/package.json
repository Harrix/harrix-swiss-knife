{
  "name": "harrix-notes-explorer",
  "displayName": "Notes Explorer",
  "description": "Custom notes panel for markdown notes",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.70.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Notes Explorer",
      "properties": {
        "notesExplorer.cliExecutable": {
          "type": "string",
          "default": "harrix-swiss-knife-cli",
          "markdownDescription": "Command or full path to `harrix-swiss-knife-cli`. Use an absolute path if the CLI is not on the PATH seen by VS Code (e.g. `.venv\\\\Scripts\\\\harrix-swiss-knife-cli.exe`)."
        },
        "notesExplorer.cliWorkingDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "Working directory for `harrix-swiss-knife-cli` commands (project root that contains `config/config.json`). Set this if your VS Code workspace is NOT the harrix-swiss-knife repo root, otherwise templates and other config-dependent commands may not work."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "notesExplorer",
          "name": "Notes",
          "icon": "$(notebook)"
        }
      ]
    },
    "commands": [
      {
        "command": "notesExplorer.refresh",
        "title": "Refresh Notes",
        "icon": "$(refresh)"
      },
      {
        "command": "notesExplorer.revealInOS",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "notesExplorer.createNote",
        "title": "Create Note..."
      },
      {
        "command": "notesExplorer.createNoteWithImages",
        "title": "Create Note with Images..."
      },
      {
        "command": "notesExplorer.renameItem",
        "title": "Rename..."
      },
      {
        "command": "notesExplorer.deleteItem",
        "title": "Delete..."
      },
      {
        "command": "notesExplorer.openMergedNote",
        "title": "Show merged note"
      },
      {
        "command": "notesExplorer.beautifyRegenerateGMd",
        "title": "Beautify Markdown and regenerate .g.md in folder"
      },
      {
        "command": "notesExplorer.newDiaryNote",
        "title": "New diary note"
      },
      {
        "command": "notesExplorer.newDreamNote",
        "title": "New dream note"
      },
      {
        "command": "notesExplorer.newCasesNote",
        "title": "New cases note"
      },
      {
        "command": "notesExplorer.addFromTemplate",
        "title": "Add from template..."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "notesExplorer.refresh",
          "when": "view == notesExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolder",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolder",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMerged",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolderWithMerged",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolderDiary",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolderDiary",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDiary",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDiary",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.newDiaryNote",
          "when": "view == notesExplorer && (viewItem == notesFolderDiary || viewItem == notesFolderWithMergedDiary)",
          "group": "1_create@3"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolderDreams",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolderDreams",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDreams",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDreams",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.newDreamNote",
          "when": "view == notesExplorer && (viewItem == notesFolderDreams || viewItem == notesFolderWithMergedDreams)",
          "group": "1_create@3"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolderCases",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolderCases",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedCases",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.createNoteWithImages",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedCases",
          "group": "1_create@2"
        },
        {
          "command": "notesExplorer.newCasesNote",
          "when": "view == notesExplorer && (viewItem == notesFolderCases || viewItem == notesFolderWithMergedCases)",
          "group": "1_create@3"
        },
        {
          "command": "notesExplorer.addFromTemplate",
          "when": "view == notesExplorer && viewItem == notesFolderTemplateTarget",
          "group": "1_create@4"
        },
        {
          "command": "notesExplorer.createNote",
          "when": "view == notesExplorer && viewItem == note",
          "group": "1_create@1"
        },
        {
          "command": "notesExplorer.openMergedNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMerged",
          "group": "navigation"
        },
        {
          "command": "notesExplorer.openMergedNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDiary",
          "group": "navigation"
        },
        {
          "command": "notesExplorer.openMergedNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDreams",
          "group": "navigation"
        },
        {
          "command": "notesExplorer.openMergedNote",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedCases",
          "group": "navigation"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolder",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderWithMerged",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderDiary",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDiary",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderDreams",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedDreams",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderCases",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderWithMergedCases",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.beautifyRegenerateGMd",
          "when": "view == notesExplorer && viewItem == notesFolderTemplateTarget",
          "group": "2_notesCli@1"
        },
        {
          "command": "notesExplorer.renameItem",
          "when": "view == notesExplorer",
          "group": "2_edit"
        },
        {
          "command": "notesExplorer.deleteItem",
          "when": "view == notesExplorer",
          "group": "2_edit"
        },
        {
          "command": "notesExplorer.revealInOS",
          "when": "view == notesExplorer",
          "group": "navigation"
        }
      ]
    }
  }
}


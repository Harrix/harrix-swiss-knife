{
  "name": "harrix-notes-explorer",
  "displayName": "Harrix Notes Explorer",
  "description": "Harrix Notes Explorer — custom notes panel for markdown notes",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.70.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Harrix Notes Explorer",
      "properties": {
        "harrixNotesExplorer.cliExecutable": {
          "type": "string",
          "default": "harrix-swiss-knife-cli",
          "markdownDescription": "Command or full path to `harrix-swiss-knife-cli`. Use an absolute path if the CLI is not on the PATH seen by VS Code (e.g. `.venv\\\\Scripts\\\\harrix-swiss-knife-cli.exe`)."
        },
        "harrixNotesExplorer.cliWorkingDirectory": {
          "type": "string",
          "default": "",
          "markdownDescription": "Working directory for `harrix-swiss-knife-cli` commands (project root that contains `config/config.json`). Set this if your VS Code workspace is NOT the harrix-swiss-knife repo root, otherwise templates and other config-dependent commands may not work."
        },
        "harrixNotesExplorer.rememberFolderExpansion": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Remember which folders were expanded or collapsed in **Harrix Notes** for this workspace (stored in workspace state). After reload or reopening VS Code, the tree restores those folders. Set to `false` to always start with every folder collapsed and not persist expansion."
        },
        "harrixNotesExplorer.openNotesInPreview": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When enabled, clicking a note in **Harrix Notes** opens the built-in **Markdown preview** (locked to that file) instead of the text editor, so each note can keep its own preview tab. The context menu on a note opens the opposite mode. When disabled, click opens the editor and the context menu opens preview. Requires the built-in Markdown extension."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "harrixNotesExplorer",
          "name": "Harrix Notes",
          "icon": "$(notebook)"
        }
      ]
    },
    "colors": [
      {
        "id": "gFile",
        "description": "Optional accent for *.g.md merged/generated notes (use in workbench.colorCustomizations).",
        "defaults": {
          "dark": "#C586C0",
          "light": "#A3158C",
          "highContrast": "#C586C0"
        }
      }
    ],
    "commands": [
      {
        "command": "harrixNotesExplorer.refresh",
        "title": "Refresh Harrix Notes",
        "icon": "$(refresh)"
      },
      {
        "command": "harrixNotesExplorer.revealInOS",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "harrixNotesExplorer.copyPath",
        "title": "Copy path"
      },
      {
        "command": "harrixNotesExplorer.openNote",
        "title": "Open note"
      },
      {
        "command": "harrixNotesExplorer.openNoteInEditor",
        "title": "Open in Editor"
      },
      {
        "command": "harrixNotesExplorer.openNoteInPreview",
        "title": "Open in Preview"
      },
      {
        "command": "harrixNotesExplorer.openMarkdownPreviewTabInEditor",
        "title": "Open in Editor"
      },
      {
        "command": "harrixNotesExplorer.createNote",
        "title": "Create Note..."
      },
      {
        "command": "harrixNotesExplorer.createNoteWithImages",
        "title": "Create Note with Images..."
      },
      {
        "command": "harrixNotesExplorer.renameItem",
        "title": "Rename..."
      },
      {
        "command": "harrixNotesExplorer.deleteItem",
        "title": "Delete..."
      },
      {
        "command": "harrixNotesExplorer.openMergedNote",
        "title": "Show merged note"
      },
      {
        "command": "harrixNotesExplorer.beautifyRegenerateGMd",
        "title": "Beautify Markdown and regenerate .g.md in folder"
      },
      {
        "command": "harrixNotesExplorer.discardGitChangesInFolder",
        "title": "Discard Git changes in folder"
      },
      {
        "command": "harrixNotesExplorer.newDiaryNote",
        "title": "New diary note"
      },
      {
        "command": "harrixNotesExplorer.newDreamNote",
        "title": "New dream note"
      },
      {
        "command": "harrixNotesExplorer.newCasesNote",
        "title": "New cases note"
      },
      {
        "command": "harrixNotesExplorer.addFromTemplate",
        "title": "Add from template..."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "harrixNotesExplorer.refresh",
          "when": "view == harrixNotesExplorer",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "harrixNotesExplorer.openMarkdownPreviewTabInEditor",
          "when": "activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'",
          "group": "1_open@5"
        }
      ],
      "commandPalette": [
        {
          "command": "harrixNotesExplorer.openMarkdownPreviewTabInEditor",
          "when": "false"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolder || viewItem == gitNotesFolder)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolder || viewItem == gitNotesFolder)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMerged || viewItem == gitNotesFolderWithMerged)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMerged || viewItem == gitNotesFolderWithMerged)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDiary || viewItem == gitNotesFolderDiary)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDiary || viewItem == gitNotesFolderDiary)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDiary || viewItem == gitNotesFolderWithMergedDiary)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDiary || viewItem == gitNotesFolderWithMergedDiary)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.newDiaryNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDiary || viewItem == notesFolderWithMergedDiary || viewItem == gitNotesFolderDiary || viewItem == gitNotesFolderWithMergedDiary)",
          "group": "1_create@3"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDreams || viewItem == gitNotesFolderDreams)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDreams || viewItem == gitNotesFolderDreams)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDreams || viewItem == gitNotesFolderWithMergedDreams)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDreams || viewItem == gitNotesFolderWithMergedDreams)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.newDreamNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDreams || viewItem == notesFolderWithMergedDreams || viewItem == gitNotesFolderDreams || viewItem == gitNotesFolderWithMergedDreams)",
          "group": "1_create@3"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderCases || viewItem == gitNotesFolderCases)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderCases || viewItem == gitNotesFolderCases)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedCases || viewItem == gitNotesFolderWithMergedCases)",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.createNoteWithImages",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedCases || viewItem == gitNotesFolderWithMergedCases)",
          "group": "1_create@2"
        },
        {
          "command": "harrixNotesExplorer.newCasesNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderCases || viewItem == notesFolderWithMergedCases || viewItem == gitNotesFolderCases || viewItem == gitNotesFolderWithMergedCases)",
          "group": "1_create@3"
        },
        {
          "command": "harrixNotesExplorer.addFromTemplate",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderTemplateTarget || viewItem == gitNotesFolderTemplateTarget)",
          "group": "1_create@4"
        },
        {
          "command": "harrixNotesExplorer.addFromTemplate",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderTemplateTargetWithMerged || viewItem == gitNotesFolderTemplateTargetWithMerged)",
          "group": "1_create@4"
        },
        {
          "command": "harrixNotesExplorer.createNote",
          "when": "view == harrixNotesExplorer && viewItem == note",
          "group": "1_create@1"
        },
        {
          "command": "harrixNotesExplorer.copyPath",
          "when": "view == harrixNotesExplorer && viewItem == note",
          "group": "navigation"
        },
        {
          "command": "harrixNotesExplorer.openNoteInEditor",
          "when": "view == harrixNotesExplorer && viewItem == note && config.harrixNotesExplorer.openNotesInPreview",
          "group": "0_open@1"
        },
        {
          "command": "harrixNotesExplorer.openNoteInPreview",
          "when": "view == harrixNotesExplorer && viewItem == note && !config.harrixNotesExplorer.openNotesInPreview",
          "group": "0_open@1"
        },
        {
          "command": "harrixNotesExplorer.copyPath",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolder || viewItem == notesFolderWithMerged || viewItem == notesFolderDiary || viewItem == notesFolderWithMergedDiary || viewItem == notesFolderDreams || viewItem == notesFolderWithMergedDreams || viewItem == notesFolderCases || viewItem == notesFolderWithMergedCases || viewItem == notesFolderTemplateTarget || viewItem == notesFolderTemplateTargetWithMerged || viewItem == gitNotesFolder || viewItem == gitNotesFolderWithMerged || viewItem == gitNotesFolderDiary || viewItem == gitNotesFolderWithMergedDiary || viewItem == gitNotesFolderDreams || viewItem == gitNotesFolderWithMergedDreams || viewItem == gitNotesFolderCases || viewItem == gitNotesFolderWithMergedCases || viewItem == gitNotesFolderTemplateTarget || viewItem == gitNotesFolderTemplateTargetWithMerged)",
          "group": "navigation"
        },
        {
          "command": "harrixNotesExplorer.openMergedNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMerged || viewItem == gitNotesFolderWithMerged)",
          "group": "navigation"
        },
        {
          "command": "harrixNotesExplorer.openMergedNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDiary || viewItem == gitNotesFolderWithMergedDiary)",
          "group": "navigation"
        },
        {
          "command": "harrixNotesExplorer.openMergedNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDreams || viewItem == gitNotesFolderWithMergedDreams)",
          "group": "navigation"
        },
        {
          "command": "harrixNotesExplorer.openMergedNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedCases || viewItem == gitNotesFolderWithMergedCases)",
          "group": "navigation"
        },
        {
          "command": "harrixNotesExplorer.openMergedNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderTemplateTargetWithMerged || viewItem == gitNotesFolderTemplateTargetWithMerged)",
          "group": "navigation"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolder || viewItem == gitNotesFolder)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMerged || viewItem == gitNotesFolderWithMerged)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDiary || viewItem == gitNotesFolderDiary)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDiary || viewItem == gitNotesFolderWithMergedDiary)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderDreams || viewItem == gitNotesFolderDreams)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedDreams || viewItem == gitNotesFolderWithMergedDreams)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderCases || viewItem == gitNotesFolderCases)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMergedCases || viewItem == gitNotesFolderWithMergedCases)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderTemplateTarget || viewItem == gitNotesFolderTemplateTarget)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.beautifyRegenerateGMd",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderTemplateTargetWithMerged || viewItem == gitNotesFolderTemplateTargetWithMerged)",
          "group": "2_notesCli@1"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolder",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderWithMerged",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderDiary",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderWithMergedDiary",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderDreams",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderWithMergedDreams",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderCases",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderWithMergedCases",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderTemplateTarget",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.discardGitChangesInFolder",
          "when": "view == harrixNotesExplorer && viewItem == gitNotesFolderTemplateTargetWithMerged",
          "group": "2_notesCli@2"
        },
        {
          "command": "harrixNotesExplorer.openMergedNote",
          "when": "view == harrixNotesExplorer && (viewItem == notesFolderWithMerged || viewItem == notesFolderWithMergedDiary || viewItem == notesFolderWithMergedDreams || viewItem == notesFolderWithMergedCases || viewItem == notesFolderTemplateTargetWithMerged || viewItem == gitNotesFolderWithMerged || viewItem == gitNotesFolderWithMergedDiary || viewItem == gitNotesFolderWithMergedDreams || viewItem == gitNotesFolderWithMergedCases || viewItem == gitNotesFolderTemplateTargetWithMerged)",
          "group": "inline"
        },
        {
          "command": "harrixNotesExplorer.renameItem",
          "when": "view == harrixNotesExplorer",
          "group": "2_edit"
        },
        {
          "command": "harrixNotesExplorer.deleteItem",
          "when": "view == harrixNotesExplorer",
          "group": "2_edit"
        },
        {
          "command": "harrixNotesExplorer.revealInOS",
          "when": "view == harrixNotesExplorer",
          "group": "navigation"
        }
      ]
    }
  }
}

